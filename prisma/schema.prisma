generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum ApplicationStatus {
  APPLIED
  INTERVIEW
  REJECTED
  OFFER
  WITHDRAWN
}

model User {
  id            String             @id @default(cuid())
  email         String             @unique
  password      String
  name          String
  role          Role               @default(USER)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  jobApplications JobApplication[]  @relation("UserApplications")
  resumes       Resume[]           @relation("UserResumes")
  notifications Notification[]     @relation("UserNotifications")
}

model JobApplication {
  id            String             @id @default(cuid())
  company       String
  role          String
  status        ApplicationStatus @default(APPLIED)
  location      String?
  salary        Int?
  deadline      DateTime?
  notes         String?
  postedAt      DateTime           @default(now())
  matchScore    Int?               @default(0)
  user          User               @relation(fields: [userId], references: [id], name: "UserApplications")
  userId        String
}

model Resume {
  id              String   @id @default(cuid())
  fileName        String
  fileSize        Int
  uploadUrl       String
  parsedText      String   @db.LongText
  score           Int      @default(0)
  suggestions     String?
  keywords        String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation("UserResumes", fields: [userId], references: [id])
  userId          String
}

model Notification {
  id        String   @id @default(cuid())
  title     String
  body      String
  delivered Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation("UserNotifications", fields: [userId], references: [id])
  userId    String
}
